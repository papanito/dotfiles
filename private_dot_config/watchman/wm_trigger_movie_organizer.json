[
  "trigger",
  "/home/papanito/Downloads",
  {
    "name": "movies-organizer",
    "expression": [
      "anyof",
      [
        "match",
        "*.mkv",
        "wholename"
      ],
      [
        "match",
        "*.mp4",
        "wholename"
      ],
      [
        "match",
        "*.srt",
        "wholename"
      ]
    ],
    "command": [
      "chezmoi",
      "add",
      "~/.config/nvim/lazyvim.json",
      "git",
      "add",
      "private_dot_config/nvim/lazyvim.json",
      "&&",
      "git",
      "commit",
      "-m",
      "'Update lazyvim config'"
    ],
    "append_files": true
  }
]
