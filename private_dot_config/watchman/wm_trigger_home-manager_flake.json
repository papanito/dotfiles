[
  "trigger",
  "/home/papanito/.config/nvim",
  {
    "name": "chezmoi-lazyvim-update",
    "expression": [
      "anyof",
      [
        "match",
        "lazy-lock.json",
        "wholename"
      ]
    ],
    "command": [
      "bash",
      "-c",
      "~/.config/watchman/chezmoi-lazyvim.sh"
    ],
    "append_files": true
  }
]
